<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- External: User -->
    <mxCell id="2" value="User&#xa;(Human)" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="20" y="160" width="40" height="60" as="geometry"/>
    </mxCell>

    <!-- External: LLM -->
    <mxCell id="3" value="Anthropic API&#xa;(Claude)" style="rounded=1;fillColor=#E8E8E8;strokeColor=#999;strokeWidth=1;fontSize=12;align=center;" vertex="1" parent="1">
      <mxGeometry x="760" y="160" width="140" height="50" as="geometry"/>
    </mxCell>

    <!-- L1: Harness Core -->
    <mxCell id="4" value="Harness Core" style="rounded=1;fillColor=#5C9EFF;strokeColor=#295FAD;strokeWidth=2;fontStyle=1;fontSize=13;fontColor=#FFF;align=center;" vertex="1" parent="1">
      <mxGeometry x="300" y="50" width="140" height="50" as="geometry"/>
    </mxCell>

    <!-- L2: Tool System -->
    <mxCell id="5" value="Tool System" style="rounded=1;fillColor=#4ECDC4;strokeColor=#16A085;strokeWidth=2;fontStyle=1;fontSize=13;fontColor=#FFF;align=center;" vertex="1" parent="1">
      <mxGeometry x="300" y="160" width="140" height="50" as="geometry"/>
    </mxCell>

    <!-- L3: Hooks -->
    <mxCell id="6" value="Hook Runner" style="rounded=1;fillColor=#FF6B6B;strokeColor=#C0392B;strokeWidth=2;fontStyle=1;fontSize=13;fontColor=#FFF;align=center;" vertex="1" parent="1">
      <mxGeometry x="300" y="270" width="140" height="50" as="geometry"/>
    </mxCell>

    <!-- L4: Multi-Agent -->
    <mxCell id="7" value="Multi-Agent" style="rounded=1;fillColor=#FFD700;strokeColor=#B8860B;strokeWidth=2;fontStyle=1;fontSize=13;fontColor=#333;align=center;" vertex="1" parent="1">
      <mxGeometry x="300" y="380" width="140" height="50" as="geometry"/>
    </mxCell>

    <!-- Tools box -->
    <mxCell id="8" value="External Tools&#xa;(Bash, Files, Web...)" style="rounded=1;fillColor=#E8E8E8;strokeColor=#999;strokeWidth=1;fontSize=12;align=center;" vertex="1" parent="1">
      <mxGeometry x="540" y="270" width="140" height="50" as="geometry"/>
    </mxCell>

    <!-- Sub-Agent -->
    <mxCell id="9" value="Sub-Agent" style="rounded=1;fillColor=#FFF8DC;strokeColor=#B8860B;strokeWidth=1;fontStyle=1;fontSize=12;align=center;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="540" y="380" width="100" height="40" as="geometry"/>
    </mxCell>

    <!-- Session DB -->
    <mxCell id="10" value="Session Store&#xa;(Messages/Metadata)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#E8E8E8;strokeColor=#999;strokeWidth=1;fontSize=11;align=center;" vertex="1" parent="1">
      <mxGeometry x="760" y="270" width="120" height="70" as="geometry"/>
    </mxCell>

    <!-- Arrow: User -> Harness -->
    <mxCell id="11" value="" style="endArrow=classic;endFill=1;strokeColor=#295FAD;strokeWidth=2;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="60" y="190" as="sourcePoint"/>
        <mxPoint x="290" y="75" as="targetPoint"/>
      </mxGeometry>
    </mxCell>

    <!-- Arrow: Harness -> LLM -->
    <mxCell id="12" value="1. messages[]" style="endArrow=classic;endFill=1;strokeColor=#295FAD;strokeWidth=2;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="450" y="70" as="sourcePoint"/>
        <mxPoint x="750" y="180" as="targetPoint"/>
      </mxGeometry>
    </mxCell>

    <!-- Arrow: LLM -> Harness -->
    <mxCell id="13" value="2. response&#xa;(tool_calls)" style="endArrow=classic;endFill=1;strokeColor=#295FAD;strokeWidth=2;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="760" y="220" as="sourcePoint"/>
        <mxPoint x="450" y="130" as="targetPoint"/>
      </mxGeometry>
    </mxCell>

    <!-- Arrow: Harness -> Tool System -->
    <mxCell id="14" value="3. tool_call" style="endArrow=classic;endFill=1;strokeColor=#16A085;strokeWidth=2;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="350" y="105" as="sourcePoint"/>
        <mxPoint x="350" y="150" as="targetPoint"/>
      </mxGeometry>
    </mxCell>

    <!-- Arrow: Tool System -> Hooks -->
    <mxCell id="15" value="4. execute()" style="endArrow=classic;endFill=1;strokeColor=#C0392B;strokeWidth=2;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="370" y="215" as="sourcePoint"/>
        <mxPoint x="370" y="260" as="targetPoint"/>
      </mxGeometry>
    </mxCell>

    <!-- PreHook check label -->
    <mxCell id="16" value="PreToolUse&#xa;Hooks" style="text;strokeColor=#C0392B;fontSize=10;fontColor=#C0392B;align=center;" vertex="1" parent="1">
      <mxGeometry x="380" y="275" width="70" height="30" as="geometry"/>
    </mxCell>

    <!-- Hooks -> External Tools -->
    <mxCell id="17" value="5. run tool" style="endArrow=classic;endFill=1;strokeColor=#666;strokeWidth=2;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="450" y="295" as="sourcePoint"/>
        <mxPoint x="530" y="295" as="targetPoint"/>
      </mxGeometry>
    </mxCell>

    <!-- External Tools -> Hooks result -->
    <mxCell id="18" value="6. result" style="endArrow=classic;endFill=1;strokeColor=#666;strokeWidth=2;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="530" y="305" as="sourcePoint"/>
        <mxPoint x="450" y="305" as="targetPoint"/>
      </mxGeometry>
    </mxCell>

    <!-- PostHook label -->
    <mxCell id="19" value="PostToolUse&#xa;Hooks" style="text;strokeColor=#C0392B;fontSize=10;fontColor=#C0392B;align=center;" vertex="1" parent="1">
      <mxGeometry x="380" y="315" width="70" height="30" as="geometry"/>
    </mxCell>

    <!-- Hooks -> Tool System result -->
    <mxCell id="20" value="7. result" style="endArrow=classic;endFill=1;strokeColor=#C0392B;strokeWidth=2;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="370" y="325" as="sourcePoint"/>
        <mxPoint x="370" y="215" as="targetPoint"/>
      </mxGeometry>
    </mxCell>

    <!-- tool System -> Harness result -->
    <mxCell id="21" value="8. tool_result" style="endArrow=classic;endFill=1;strokeColor=#16A085;strokeWidth=2;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="350" y="165" as="sourcePoint"/>
        <mxPoint x="350" y="105" as="targetPoint"/>
      </mxGeometry>
    </mxCell>

    <!-- Harness -> Session Store -->
    <mxCell id="22" value="9. persist" style="endArrow=classic;endFill=1;strokeColor=#999;strokeWidth=1;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="450" y="75" as="sourcePoint"/>
        <mxPoint x="750" y="275" as="targetPoint"/>
      </mxGeometry>
    </mxCell>

    <!-- Harness -> Multi-Agent -->
    <mxCell id="23" value="10. fork/resume" style="endArrow=classic;endFill=1;strokeColor=#B8860B;strokeWidth=2;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="380" y="100" as="sourcePoint"/>
        <mxPoint x="530" y="400" as="targetPoint"/>
      </mxGeometry>
    </mxCell>

    <!-- Multi-Agent -> Sub-Agent -->
    <mxCell id="24" value="11. delegate" style="endArrow=classic;endFill=1;strokeColor=#B8860B;strokeWidth=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="550" y="400" as="sourcePoint"/>
        <mxPoint x="530" y="400" as="targetPoint"/>
      </mxGeometry>
    </mxCell>

    <!-- Sub-Agent messages back -->
    <mxCell id="25" value="12. result" style="endArrow=classic;endFill=1;strokeColor=#B8860B;strokeWidth=1;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="530" y="390" as="sourcePoint"/>
        <mxPoint x="450" y="100" as="targetPoint"/>
      </mxGeometry>
    </mxCell>

    <!-- Step labels box -->
    <mxCell id="26" value="Data Flow Summary&#xa;&#xa;1.  User → Harness: input&#xa;2.  Harness → LLM: messages[]&#xa;3.  LLM → Harness: tool_calls&#xa;4.  Harness → ToolSystem: execute()&#xa;5.  ToolSystem → Hooks → Tools&#xa;6.  Tools result → Hooks → ToolSystem&#xa;7.  ToolSystem → Harness: result&#xa;8.  Harness → Session: persist&#xa;9.  Harness ↔ MultiAgent: fork/resume&#xa;&#xa;Loop continues until finish" style="text;strokeColor=#666;fillColor=#F5F5F5;fontSize=10;align=left;spacingLeft=8;strokeWidth=1;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="20" y="300" width="220" height="180" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
